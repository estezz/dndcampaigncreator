<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>D&D Campaign Master File</title>
    <style>
        :root {
            --bg-parchment: #fdf6e3;
            --bg-dark: #1a1a1a;
            --text-main: #333;
            --header-red: #8b0000;
            --accent-gold: #c5a059;
            --stat-block-bg: #f2eecb;
        }

        body {
            font-family: 'Book Antiqua', 'Palatino Linotype', serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            margin: 0;
            padding: 20px;
        }

        .container {
            background-color: var(--bg-parchment);
            max-width: 1000px;
            margin: 0 auto;
            padding: 50px;
            box-shadow: 0 0 15px rgba(0,0,0,0.7);
            border: 1px solid #d4c4a0;
        }

        /* Navigation / TOC */
        .toc {
            background: rgba(0,0,0,0.05);
            padding: 20px;
            border: 1px solid var(--accent-gold);
            margin-bottom: 40px;
        }
        .toc h3 { margin-top: 0; border: none; }
        .toc ul { column-count: 2; }
        .toc a { text-decoration: none; color: var(--header-red); font-weight: bold; }
        .toc a:hover { text-decoration: underline; }

        /* Typography */
        h1, h2, h3 {
            color: var(--header-red);
            border-bottom: 2px solid var(--accent-gold);
            padding-bottom: 5px;
        }
        h1 { text-align: center; text-transform: uppercase; letter-spacing: 2px; font-size: 2.5em; }
        
        /* Layout Utilities */
        .section { margin-bottom: 50px; scroll-margin-top: 20px; }
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        
        /* Plot Twist Box */
        .twist-box {
            border: 2px dashed var(--header-red);
            background-color: #fff0f0;
            padding: 15px;
            margin: 10px 0;
        }
        .twist-box strong { color: var(--header-red); text-transform: uppercase; }

        /* Map Section */
        .map-container {
            width: 100%;
            height: 400px;
            background-color: #ddd;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 5px double var(--accent-gold);
            margin: 20px 0;
            color: #555;
            font-style: italic;
        }
        .map-container img {
            max-width: 100%;
            max-height: 100%;
        }

        /* NPC Cards */
        .npc-card {
            border: 1px solid var(--accent-gold);
            padding: 15px;
            background: white;
            box-shadow: 2px 2px 5px rgba(0,0,0,0.1);
        }
        .npc-role { font-size: 0.9em; color: #666; font-style: italic; }

        /* Monster Stat Block */
        .stat-block {
            background-color: var(--stat-block-bg);
            border: 2px solid #c9ad6a;
            padding: 15px;
            font-family: sans-serif;
            margin-bottom: 20px;
            box-shadow: 3px 3px 8px rgba(0,0,0,0.2);
        }
        .stat-block h3 { border: none; margin: 0; font-family: serif; font-variant: small-caps; font-size: 1.5em; color: var(--header-red); }
        .stat-block hr { border: 0; height: 2px; background: var(--header-red); margin: 10px 0; }
        .stat-line { margin: 5px 0; }
        
        /* Loot Table */
        table.loot-table {
            width: 100%;
            border-collapse: collapse;
        }
        table.loot-table th, table.loot-table td {
            border: 1px solid var(--accent-gold);
            padding: 8px;
            text-align: left;
        }
        table.loot-table th { background: rgba(197, 160, 89, 0.2); }
        /* --- Main Container --- */
        .stat-block {
            background: var(--bg-color);
            width: 400px;
            padding: 15px;
            box-shadow: 0 0 15px rgba(0,0,0,0.5);
            border: 1px solid #d4c4a9;
            box-sizing: border-box;
        }

        /* --- Typography --- */
        .stat-block h1 {
            font-family: var(--font-header);
            color: var(--header-color);
            font-size: 24px;
            margin: 5px 0 0 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .stat-block h2 {
            font-style: italic;
            font-size: 12px;
            margin: 0 0 10px 0;
            color: #333;
        }

        .stat-block h4 {
            display: inline;
            font-weight: bold;
            color: var(--header-color);
            margin: 0;
        }

        .stat-block p {
            margin: 2px 0;
            font-size: 14px;
            line-height: 1.4em;
            color: var(--header-color);
        }

        .property-line p {
            display: inline;
            color: #000;
        }

        /* --- Separators (The Tapered Line) --- */
        .tapered-rule {
            display: block;
            height: 2px;
            border: none;
            margin: 10px 0;
            background: linear-gradient(90deg, transparent 0%, var(--separator-color) 50%, transparent 100%);
        }

        /* --- Ability Score Grid --- */
        .abilities {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            text-align: center;
            color: var(--header-color);
            margin: 10px 0;
        }

        .abilities div h4 {
            display: block;
            margin-bottom: 2px;
            font-size: 12px;
        }

        .abilities div p {
            margin: 0;
            font-size: 14px;
        }

        /* --- Bottom Section (CR, XP, PB) --- */
        .actions {
            margin-top: 10px;
        }

    </style>
</head>
<body>

<div class="container">

    <header>
        <h1>{{title}}</h1>
        <p style="text-align: center;">Target Level: 1-5 | Setting: Forgotten Realms</p>
    </header>

    <div class="toc">
        <h3>Campaign Contents</h3>
        <ul>
            <li><a href="#setup">1. Setup & Background</a></li>
            <li><a href="#start">2. Starting Point</a></li>
            <li><a href="#hooks">3. Plot Hooks</a></li>
            <li><a href="#mainplot">4. Main Plot Steps</a></li>
            <li><a href="#twists">5. Plot Twists</a></li>
            <li><a href="#map">6. Regional Map</a></li>
            <li><a href="#npcs">7. Main Characters</a></li>
            <li><a href="#monsters">8. Monsters</a></li>
            <li><a href="#rewards">9. Rewards</a></li>
        </ul>
    </div>

    <div id="setup" class="section">
        <h2>1. Setup & Background</h2>
        <p><strong>Setting:</strong> {{setting}} </p>
        <p><strong>History:</strong> {{history}} </p>
        <p><strong>Atmosphere:</strong> {{atmosphere}} </p>
        <p><strong>Setup:</strong> {{setup}} </p>
    </div>

    <div id="start" class="section">
        <h2>2. Starting Point</h2>
        <img src="{{startingPointImage.url}}" alt="{{startingPointImage.description}}" style="map" width="100%" />
        <p></p>
    </div>

    <div id="hooks" class="section">
        <h2>3. Plot Hooks</h2>
         <ol>
            {% for plotHook in plotHooks %}
                <li>{{ plotHook.title }} - {{ plotHook.description }}</li>
            {% endfor %}
        </ol>
    </div>

    <div id="mainplot" class="section">
        <h2>4. Main Plot Steps</h2>
        <ol>
            {% for plotStep in mainPlotSteps %}
                <li>{{ plotStep.title }} - {{ plotStep.description }}</li>
            {% endfor %}
        </ol>
    </div>

    <div id="twists" class="section">
        <h2>5. Plot Twists</h2>
            {% for plotTwist in generatedPlotTwists %}
                <div class="twist-box">
                    <strong>{{ plotTwist.title }}</strong>
                    <p>{{ plotTwist.description }}</p>
                </div>
            {% endfor %}
    </div>

    <div id="map" class="section">
        <h2>6. Regional Map</h2>
        <div class="map-container">
            <img src="{{ mapImagePrompt.url }}"" alt="{{regionalMapTitle}}" style="map" width="100%" />
        </div>
        <p><em>Key Locations: 1. The Capital, 2. The Ruins, 3. The Forbidden Forest.</em></p>
    </div>

    <div id="npcs" class="section">
        <h2>7. Main Characters</h2>
        <div class="grid-2">
            {% for character in mainCharacters %}
                <div class="npc-card">
                    <h3>{{character.name}}</h3>
                    <img src="{{character.image.url}}" alt="{{character.name}}" style="image" width="90%" />
                    <div class="npc-role">{{character.role}}</div>
                    <p><strong>Goal:</strong> {{character.goal}}</p>
                    <p><strong>Quirk:</strong> {{character.quirk}}</p>
                </div>
           {% endfor %}
        </div>
    </div>

    <div id="monsters" class="section">
        <h2>8. Monsters</h2>
            {% for monster in monsters %}
            
                <div class="stat-block">
                    <hr class="tapered-rule">
                    
                    <div class="creature-heading">
                        <h1>{{monster.name}}</h1>
                        <h2>{{monster.description}}</h2>
                        <img src="{{monster.image.url}}" alt="{{monster.name}}" style="map" width="100%" />
                    </div>
                    
                    <hr class="tapered-rule">

                    <div class="top-stats">
                        <div class="property-line">
                            <h4>{{monster.stats.AC}} (AC)</h4>
                            <p>15 (natural armor)</p> </div>
                        <div class="property-line">
                            <h4>{{monster.stats.HP}} (HP)</h4>
                            <p>45</p> </div>
                        <div class="property-line">
                            <h4>Speed</h4>
                            <p>{{monster.stats.Speed}} ft - {{monster.stats.Swim}} ft swim.</p> </div>
                        <div class="property-line">
                            <h4>Initiative</h4>
                            <p>{{monster.stats.Initiative}}</p> </div>
                    </div>

                    <hr class="tapered-rule">

                    <div class="abilities">
                        <div>
                            <h4>STR</h4>
                            <p>{{monster.stats.Str}} (+{{monster.stats.Str - 10}})</p>
                        </div>
                        <div>
                            <h4>DEX</h4>
                            <p>{{monster.stats.Dex}} (+{{monster.stats.Dex - 10}})</p>
                        </div>
                        <div>
                            <h4>CON</h4>
                            <p>{{monster.stats.Con}} (+{{monster.stats.Con - 10}})</p>
                        </div>
                        <div>
                            <h4>INT</h4>
                            <p>{{monster.stats.Int}} (+{{monster.stats.Int - 10}})</p>
                        </div>
                        <div>
                            <h4>WIS</h4>
                            <p>{{</p>
                        </div>
                        <div>
                            <h4>CHA</h4>
                            <p>{{monster.stats.Cha}} (+{{monster.stats.Cha - 10}})</p>
                        </div>
                    </div>

                    <hr class="tapered-rule">

                    <div class="bottom-stats">
                        <div class="property-line">
                            <h4>Challenge</h4>
                            <p>{{monster.stats.CR}}-{{monster.stats.XP}}(XP)</p> </div>
                        <div class="property-line">
                            <h4>Proficiency Bonus</h4>
                            <p>{{monster.stats.PB}}</p> </div>
                    </div>
                    <div class="bottom-stats">
                        <div class="stat-line">
                            <h4>Traits</h4>
                            <p>{{monster.Traits}}</p> </div>
                    </div>  
                    
                    <hr class="tapered-rule">
                </div>   
            {% endfor %}
    </div>

    <div id="rewards" class="section">
        <h2>9. Rewards</h2>
        <table class="loot-table">
            <thead>
                <tr>
                    <th>Item Name</th>
                    <th>Type</th>
                    <th>Value</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Potion of Healing</td>
                    <td>Consumable</td>
                    <td>50gp</td>
                    <td>2d4+2 HP</td>
                </tr>
                <tr>
                    <td>Sword of Warning</td>
                    <td>Weapon (Magic)</td>
                    <td>Uncommon</td>
                    <td>Advantage on Initiative</td>
                </tr>
                <tr>
                    <td>Gemstones</td>
                    <td>Currency</td>
                    <td>100gp</td>
                    <td>Small rubies</td>
                </tr>
            </tbody>
        </table>
    </div>

</div>
</body>
</html>