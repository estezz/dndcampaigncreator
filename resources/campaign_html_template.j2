<!DOCTYPE html>
<container id="content-to-download" style="border: 1px solid black; padding: 10px;">
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>D&D Campaign Master File</title>
    <style>
        :root {
            --bg-parchment: #fdf6e3;
            --bg-dark: #1a1a1a;
            --text-main: #333;
            --header-red: #8b0000;
            --accent-gold: #c5a059;
            --stat-block-bg: #f2eecb;
        }

        body {
            font-family: 'Book Antiqua', 'Palatino Linotype', serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            margin: 0;
            padding: 20px;
        }

        .container {
            background-color: var(--bg-parchment);
            max-width: 1000px;
            margin: 0 auto;
            padding: 50px;
            box-shadow: 0 0 15px rgba(0,0,0,0.7);
            border: 1px solid #d4c4a0;
        }

        /* Navigation / TOC */
        .toc {
            background: rgba(0,0,0,0.05);
            padding: 20px;
            border: 1px solid var(--accent-gold);
            margin-bottom: 40px;
        }
        .toc h3 { margin-top: 0; border: none; }
        .toc ul { column-count: 2; }
        .toc a { text-decoration: none; color: var(--header-red); font-weight: bold; }
        .toc a:hover { text-decoration: underline; }

        /* Typography */
        .title {
            color: var(--header-red);
            border-bottom: 2px solid var(--accent-gold);
            padding-bottom: 5px;
            text-align: center; text-transform: uppercase; letter-spacing: 2px; font-size: 2.5em;
        }

        /* Typography */
        h1, h2, h3 {
            color: var(--header-red);
            border-bottom: 2px solid var(--accent-gold);
            padding-bottom: 5px;
        }
        h1 { text-align: center; text-transform: uppercase; letter-spacing: 2px; font-size: 2.5em; }
        
        /* Layout Utilities */
        .section { margin-bottom: 50px; scroll-margin-top: 20px; }
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        
        /* Plot Twist Box */
        .twist-box {
            border: 2px dashed var(--header-red);
            background-color: #fff0f0;
            padding: 15px;
            margin: 10px 0;
        }
        .twist-box strong { color: var(--header-red); text-transform: uppercase; }

        /* Map Section */
        .map-container {
            width: 100%;
            height: 400px;
            background-color: #ddd;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 5px double var(--accent-gold);
            margin: 20px 0;
            color: #555;
            font-style: italic;
        }
        .map-container img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain
        }

        /* NPC Cards */
        .npc-card {
            border: 1px solid var(--accent-gold);
            padding: 15px;
            background: white;
            box-shadow: 2px 2px 5px rgba(0,0,0,0.1);
        }
        .npc-role { font-size: 0.9em; color: #666; font-style: italic; }

        /* Monster Stat Block */
        .stat-block {
            background-color: var(--stat-block-bg);
            border: 2px solid #c9ad6a;
            padding: 15px;
            font-family: sans-serif;
            margin-bottom: 20px;
            box-shadow: 3px 3px 8px rgba(0,0,0,0.2);
        }
        .stat-block h3 { border: none; margin: 0; font-family: serif; font-variant: small-caps; font-size: 1.5em; color: var(--header-red); }
        .stat-block hr { border: 0; height: 2px; background: var(--header-red); margin: 10px 0; }
        .stat-line { margin: 5px 0; }
        
        /* Loot Table */
        table.loot-table {
            width: 100%;
            border-collapse: collapse;
        }
        table.loot-table th, table.loot-table td {
            border: 1px solid var(--accent-gold);
            padding: 8px;
            text-align: left;
        }
        table.loot-table th { background: rgba(197, 160, 89, 0.2); }
        /* --- Main Container --- */
        .stat-block {
            background: var(--bg-color);
            width: 400px;
            padding: 15px;
            box-shadow: 0 0 15px rgba(0,0,0,0.5);
            border: 1px solid #d4c4a9;
            box-sizing: border-box;
        }

        /* --- Typography --- */
        .stat-block h1 {
            font-family: var(--font-header);
            color: var(--header-color);
            font-size: 24px;
            margin: 5px 0 0 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .stat-block h2 {
            font-style: italic;
            font-size: 12px;
            margin: 0 0 10px 0;
            color: #333;
        }

        .stat-block h4 {
            display: inline;
            font-weight: bold;
            color: var(--header-color);
            margin: 0;
        }

        .stat-block p {
            margin: 2px 0;
            font-size: 14px;
            line-height: 1.4em;
            color: var(--header-color);
        }

        .property-line p {
            display: inline;
            color: #000;
        }

        /* --- Separators (The Tapered Line) --- */
        .tapered-rule {
            display: block;
            height: 2px;
            border: none;
            margin: 10px 0;
            background: linear-gradient(90deg, transparent 0%, var(--separator-color) 50%, transparent 100%);
        }

        /* --- Ability Score Grid --- */
        .abilities {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            text-align: center;
            color: var(--header-color);
            margin: 10px 0;
        }

        .abilities div h4 {
            display: block;
            margin-bottom: 2px;
            font-size: 12px;
        }

        .abilities div p {
            margin: 0;
            font-size: 14px;
        }

    </style>        
    <script>
        function downloadPartialHTML() {
            // 1. Get the content of the target element
            const content = document.getElementById('content-to-download').innerHTML;
            
            // 2. Create a blob from the HTML content
            const blob = new Blob([content], { type: 'text/html' });
            
            // 3. Create a temporary anchor element
            const a = document.createElement('a');
            a.download = "{{title | escape}}.html"; // Set the filename
            a.href = URL.createObjectURL(blob);
            
            // 4. Trigger the download
            a.click();
            
            // 5. Clean up
            URL.revokeObjectURL(a.href);
        }

        function regenerateImage(domId) {
            alert("regenerating image" + domId);
            const mapImage = document.getElementById(domId);
            document.getElementById( mapImage ).src="https://www.imatest.com/wp-content/uploads/2020/06/LabReflectiveModule-3-2-RESIZED.jpg"
        }
    </script>
</head>
<body>

<div class="container">

    <header>
        <div class="title">{{title}}</div>
        <p style="text-align: center; font-weight: bold; font-style: italic; font-size: 20px">Target Level: 1-5 | Setting: Forgotten Realms</p>
    </header>
    <button class="dragon-btn" onclick="downloadPartialHTML()">
        <span class="dragon-scales"></span>
        <span class="btn-text">Download as HTML</span>
    </button>
    <br/>
    <br/>
    <div class="toc">
        <h3>Campaign Contents</h3>
        <ul>
            <li><a href="#setup">1. Setup & Background</a></li>
            <li><a href="#start">2. Starting Point</a></li>
            <li><a href="#hooks">3. Plot Hooks</a></li>
            <li><a href="#mainplot">4. Main Plot Steps</a></li>
            <li><a href="#twists">5. Plot Twists</a></li>
            <li><a href="#map">6. Regional Map</a></li>
            <li><a href="#npcs">7. Main Characters</a></li>
            <li><a href="#monsters">8. Monsters</a></li>
            <li><a href="#rewards">9. Rewards</a></li>
        </ul>
    </div>

    <div id="setup" class="section">
        <h2>1. Setup & Background</h2>
        <p><strong>Setting:</strong> {{setting}} </p>
        <p><strong>History:</strong> {{history}} </p>
        <p><strong>Atmosphere:</strong> {{atmosphere}} </p>
        <p><strong>Setup:</strong> {{setup}} </p>
    </div>

    <div id="start" class="section">
        <h2>2. Starting Point</h2>
        <p><strong>Starting Point:</strong> {{startingPoint}}</p>
        <p style="text-align: center;">
            <img src="{{startingPointImage.url}}" alt="{{startingPointImage.description}}" style="map" width="80%" />
        </p>
    </div>

    <div id="hooks" class="section">
        <h2>3. Plot Hooks</h2>
         <ol>
            {% for plotHook in plotHooks %}
                <li>
                    <h3>{{ plotHook.title }}</h3>
                    <p>{{ plotHook.description }}</p>
                </li>
            {% endfor %}
        </ol>
    </div>

    <div id="mainplot" class="section">
        <h2>4. Main Plot Steps</h2>
        <ol>
            {% for plotStep in mainPlotSteps %}
                <li>
                    <h3>{{ plotStep.title }}</h3>
                    <p>{{ plotStep.description }}</p>
                </li>
            {% endfor %}
        </ol>
    </div>

    <div id="twists" class="section">
        <h2>5. Plot Twists</h2>
            {% for plotTwist in generatedPlotTwists %}
                <div class="twist-box">
                    <strong>{{ plotTwist.title }}</strong>
                    <p>{{ plotTwist.description }}</p>
                </div>
            {% endfor %}
    </div>

    <div id="map" class="section">
        <h2>6. Regional Map</h2>
        <div class="map-container">
                <p style="text-align: center;" >
                    <img id="regionalMap" src="{{ mapImagePrompt.url }}"" alt="{{regionalMapTitle}}" style="map; object-fit: contain" width="90%" />
                    <button onclick="regenerateImage('regionalMap')">Regenerate Map</button>
                </p>
        </div>
        <p><em>Key Locations: 1. The Capital, 2. The Ruins, 3. The Forbidden Forest.</em></p>
    </div>

    <div id="npcs" class="section">
        <h2>7. Main Characters</h2>
        <div class="grid-2">
            {% for character in mainCharacters %}
                 <div class="stat-block">
                    <hr class="tapered-rule">
                    <h3>{{character.name}}</h3>
                    <p style="text-align: center;">
                        <img src="{{character.image.url}}" alt="{{character.name}}" style="image" width="80%" />
                    </p>
                    <div class="npc-role">{{character.role}}</div>
                    <hr class="tapered-rule">

                    <div class="top-stats">
                        <div class="property-line">
                            <h4>{{character.stats.AC}} (AC)</h4>
                            <p>15 (natural armor)</p> </div>
                        <div class="property-line">
                            <h4>{{character.stats.HP}} (HP)</h4>
                            <p>45</p> </div>
                        <div class="property-line">
                            <h4>Speed</h4>
                            <p>{{character.stats.Speed}} ft - {{character.stats.Swim}} ft swim.</p> </div>
                        <div class="property-line">
                            <h4>Initiative</h4>
                            <p>{{character.stats.Initiative}}</p> </div>
                    </div>

                    <hr class="tapered-rule">

                    <div class="abilities">
                        <div>
                            <h4>STR</h4>
                            <p>{{character.stats.Str}} (+{{character.stats.Str - 10}})</p>
                        </div>
                        <div>
                            <h4>DEX</h4>
                            <p>{{character.stats.Dex}} (+{{character.stats.Dex - 10}})</p>
                        </div>
                        <div>
                            <h4>CON</h4>
                            <p>{{character.stats.Con}} (+{{character.stats.Con - 10}})</p>
                        </div>
                        <div>
                            <h4>INT</h4>
                            <p>{{character.stats.Int}} (+{{character.stats.Int - 10}})</p>
                        </div>
                        <div>
                            <h4>WIS</h4>
                            <p>{{character.stats.Wis}} (+{{character.stats.Wis - 10}})</p>
                        </div>
                        <div>
                            <h4>CHA</h4>
                            <p>{{character.stats.Cha}} (+{{character.stats.Cha - 10}})</p>
                        </div>
                    </div>

                    <hr class="tapered-rule">

                    <div class="bottom-stats">
                        <div class="property-line">
                            <h4>Challenge</h4>
                            <p>{{character.stats.CR}}-{{character.stats.XP}}(XP)</p> </div>
                        <div class="property-line">
                            <h4>Proficiency Bonus</h4>
                            <p>{{character.stats.PB}}</p> </div>
                    </div>
                    <div class="bottom-stats">
                        <div class="stat-line">
                            <h4>Traits</h4>
                            <p>{{character.Traits}}</p> </div>
                    </div>  
                    
                    <p><strong>Goal:</strong> {{character.goal}}</p>
                    <p><strong>Quirk:</strong> {{character.quirk}}</p>

                    <hr class="tapered-rule">
                </div>
           {% endfor %}
        </div>
    </div>

    <div id="monsters" class="section">
        <h2>8. Monsters</h2>
        <div class="grid-2">
            {% for monster in monsters %}
            
                <div class="stat-block">
                    <hr class="tapered-rule">
                    
                    <div class="creature-heading">
                        <h1>{{monster.name}}</h1>
                        <h2>{{monster.description}}</h2>
                        <p style="text-align: center;">
                            <img src="{{monster.image.url}}" alt="{{monster.name}}" style="map" width="80%" />
                        </p>
                    </div>
                    
                    <hr class="tapered-rule">

                    <div class="top-stats">
                        <div class="property-line">
                            <h4>{{monster.stats.AC}} (AC)</h4>
                            <p>15 (natural armor)</p> </div>
                        <div class="property-line">
                            <h4>{{monster.stats.HP}} (HP)</h4>
                            <p>45</p> </div>
                        <div class="property-line">
                            <h4>Speed</h4>
                            <p>{{monster.stats.Speed}} ft - {{monster.stats.Swim}} ft swim.</p> </div>
                        <div class="property-line">
                            <h4>Initiative</h4>
                            <p>{{monster.stats.Initiative}}</p> </div>
                    </div>

                    <hr class="tapered-rule">

                    <div class="abilities">
                        <div>
                            <h4>STR</h4>
                            <p>{{monster.stats.Str}} (+{{monster.stats.Str - 10}})</p>
                        </div>
                        <div>
                            <h4>DEX</h4>
                            <p>{{monster.stats.Dex}} (+{{monster.stats.Dex - 10}})</p>
                        </div>
                        <div>
                            <h4>CON</h4>
                            <p>{{monster.stats.Con}} (+{{monster.stats.Con - 10}})</p>
                        </div>
                        <div>
                            <h4>INT</h4>
                            <p>{{monster.stats.Int}} (+{{monster.stats.Int - 10}})</p>
                        </div>
                        <div>
                            <h4>WIS</h4>
                            <p>{{monster.stats.Wis}} (+{{monster.stats.Wis - 10}})</p>
                        </div>
                        <div>
                            <h4>CHA</h4>
                            <p>{{monster.stats.Cha}} (+{{monster.stats.Cha - 10}})</p>
                        </div>
                    </div>

                    <hr class="tapered-rule">

                    <div class="bottom-stats">
                        <div class="property-line">
                            <h4>Challenge</h4>
                            <p>{{monster.stats.CR}}-{{monster.stats.XP}}(XP)</p> </div>
                        <div class="property-line">
                            <h4>Proficiency Bonus</h4>
                            <p>{{monster.stats.PB}}</p> </div>
                    </div>
                    <div class="bottom-stats">
                        <div class="stat-line">
                            <h4>Traits</h4>
                            <p>{{monster.Traits}}</p> </div>
                    </div>  
                    
                    <hr class="tapered-rule">
                </div>   
            {% endfor %}
        </div>
    </div>

    <div id="rewards" class="section">
        <h2>9. Rewards</h2>
        {%  for reward in rewardsList %}
            <div class="reward-block" >
                <h3 style="text-align: left; ">{{reward.name}}</h4>
                <p style="text-align: center;">{{reward.description}}</p>
                <p style="text-align: center;">                        
                    <img src="{{reward.image.url}}" alt="{{reward.name}}" style="map" width="80%" />
                </p>
            </div>
        {% endfor %}
    </div>

    <div id="magicItems" class="section">
        <h2>10. Magic Items</h2>
        {%  for item in generatedMagicItems %}
            <div class="reward-block" >
                <h3 style="text-align: left;">{{item.name}}</h4>
                <p style="text-align: center;">{{item.description}}</p>
                <p style="text-align: center;">
                    <img src="{{item.image.url}}" alt="{{item.name}}"  width="50%" align=center/>
                </p>
            </div>
        {% endfor %}
    </div>
</div>
</body>
</html>
</container>